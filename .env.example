# Configuration pour la traduction automatique avec Claude

# Clé API Anthropic (Claude)
# Obtenez votre clé sur: https://console.anthropic.com/
ANTHROPIC_API_KEY=votre_clé_api_ici

# Configuration de l'authentification admin
# Changez ces valeurs pour sécuriser votre admin !
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Environnement (development ou production)
NODE_ENV=development

# Note: Renommez ce fichier en .env et ajoutez vos vraies valeurs
# IMPORTANT: Changez le mot de passe par défaut !