// ===== ADMIN I18N MANAGER =====
class AdminI18n {
    constructor() {
        this.currentLang = localStorage.getItem('adminLanguage') || 'fr';
        this.translations = adminTranslations;
    }
    
    // Get current language
    getCurrentLang() {
        return this.currentLang;
    }
    
    // Set language
    setLang(lang) {
        if (this.translations[lang]) {
            this.currentLang = lang;
            localStorage.setItem('adminLanguage', lang);
            this.updateUI();
            return true;
        }
        return false;
    }
    
    // Get translation by key path (e.g., "sidebar.title")
    t(keyPath) {
        const keys = keyPath.split('.');
        let value = this.translations[this.currentLang];
        
        for (const key of keys) {
            if (value && typeof value === 'object') {
                value = value[key];
            } else {
                return keyPath; // Return key if not found
            }
        }
        
        return value || keyPath;
    }
    
    // Update all UI elements with data-i18n attribute
    updateUI() {
        document.querySelectorAll('[data-i18n]').forEach(element => {
            const key = element.getAttribute('data-i18n');
            const translation = this.t(key);
            
            if (element.tagName === 'INPUT' || element.tagName === 'TEXTAREA') {
                element.placeholder = translation;
            } else {
                element.textContent = translation;
            }
        });
        
        // Update language selector buttons
        document.querySelectorAll('.admin-lang-btn').forEach(btn => {
            btn.classList.toggle('active', btn.dataset.lang === this.currentLang);
        });
        
        console.log(`✅ Admin UI updated to: ${this.currentLang}`);
    }
    
    // Initialize i18n system
    init() {
        this.updateUI();
        this.bindLanguageSelector();
        console.log('✅ Admin i18n initialized');
    }
    
    // Bind language selector buttons
    bindLanguageSelector() {
        document.querySelectorAll('.admin-lang-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                const lang = btn.dataset.lang;
                this.setLang(lang);
            });
        });
    }
}

// Create global instance
const adminI18n = new AdminI18n();

// Initialize immediately - don't wait
adminI18n.bindLanguageSelector();
console.log('✅ Admin i18n instance created and ready');

// Auto-initialize UI when DOM is ready
if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', () => {
        adminI18n.updateUI();
        console.log('✅ Admin i18n UI initialized on DOMContentLoaded');
    });
} else {
    adminI18n.updateUI();
    console.log('✅ Admin i18n UI initialized immediately');
}

// Expose methods globally
window.adminI18n = adminI18n;
window.refreshAdminTranslations = () => {
    adminI18n.updateUI();
    console.log('🔄 Admin translations refreshed');
};

console.log('✅ Admin i18n module loaded');

