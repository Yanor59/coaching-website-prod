// ===== SAVE PHOTO =====
async function savePhoto() {
    const index = parseInt(document.getElementById('photo-index').value);
    const url = document.getElementById('photo-url').value.trim();
    
    if (!url) {
        alert('Veuillez entrer une URL d\'image');
        return;
    }
    
    const photoData = {
        url: url,
        caption: {}
    };
    
    // Get captions for all languages
    ['fr', 'en', 'sk', 'ua'].forEach(lang => {
        const input = document.getElementById(`photo-caption-${lang}`);
        photoData.caption[lang] = input ? input.value.trim() : '';
    });
    
    // Update all languages
    ['fr', 'en', 'sk', 'ua'].forEach(lang => {
        if (!galleryData[lang].photos) {
            galleryData[lang].photos = [];
        }
        
        const photo = {
            url: photoData.url,
            caption: photoData.caption[lang]
        };
        
        if (index >= 0) {
            galleryData[lang].photos[index] = photo;
        } else {
            galleryData[lang].photos.push(photo);
        }
        
        siteContent.content[lang].gallery = galleryData[lang];
    });
    
    // Save to server
    const success = await saveSiteContent();
    
    if (success) {
        document.getElementById('photo-modal').classList.remove('active');
        renderGalleryManager();
        showNotification('Photo enregistrée avec succès', 'success');
    } else {
        showNotification('Erreur lors de l\'enregistrement', 'error');
    }
}

// ===== SAVE VIDEO =====
async function saveVideo() {
    const index = parseInt(document.getElementById('video-index').value);
    const url = document.getElementById('video-url').value.trim();
    
    if (!url) {
        alert('Veuillez entrer une URL YouTube');
        return;
    }
    
    // Validate YouTube URL
    const videoId = extractYouTubeId(url);
    if (!videoId) {
        alert('URL YouTube invalide');
        return;
    }
    
    const videoData = {
        url: url,
        title: {}
    };
    
    // Get titles for all languages
    ['fr', 'en', 'sk', 'ua'].forEach(lang => {
        const input = document.getElementById(`video-title-${lang}`);
        videoData.title[lang] = input ? input.value.trim() : '';
    });
    
    // Check if at least FR title is provided
    if (!videoData.title.fr) {
        alert('Veuillez entrer un titre en français');
        return;
    }
    
    // Update all languages
    ['fr', 'en', 'sk', 'ua'].forEach(lang => {
        if (!galleryData[lang].videos) {
            galleryData[lang].videos = [];
        }
        
        const video = {
            url: videoData.url,
            title: videoData.title[lang] || videoData.title.fr
        };
        
        if (index >= 0) {
            galleryData[lang].videos[index] = video;
        } else {
            galleryData[lang].videos.push(video);
        }
        
        siteContent.content[lang].gallery = galleryData[lang];
    });
    
    // Save to server
    const success = await saveSiteContent();
    
    if (success) {
        document.getElementById('video-modal').classList.remove('active');
        renderGalleryManager();
        showNotification('Vidéo enregistrée avec succès', 'success');
    } else {
        showNotification('Erreur lors de l\'enregistrement', 'error');
    }
}

// ===== DELETE PHOTO =====
async function deletePhoto(index) {
    const t = (key) => typeof adminI18n !== 'undefined' ? adminI18n.t(key) : key;
    
    if (!confirm(t('galleryManager.confirmDeletePhoto'))) {
        return;
    }
    
    // Remove from all languages
    ['fr', 'en', 'sk', 'ua'].forEach(lang => {
        if (galleryData[lang].photos && galleryData[lang].photos[index]) {
            galleryData[lang].photos.splice(index, 1);
            siteContent.content[lang].gallery = galleryData[lang];
        }
    });
    
    const success = await saveSiteContent();
    
    if (success) {
        renderGalleryManager();
        showNotification('Photo supprimée avec succès', 'success');
    } else {
        showNotification('Erreur lors de la suppression', 'error');
    }
}

