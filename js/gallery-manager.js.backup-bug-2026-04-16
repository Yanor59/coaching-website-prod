// ===== RENDER PHOTOS LIST =====
function renderPhotosList(photos) {
    if (!Array.isArray(photos)) {
        console.warn('Photos is not an array:', photos);
        return '<div class="empty-state"><p>📷 Aucune photo</p></div>';
    }
    return photos.map((photo, index) => `
        <div class="gallery-item photo-item" data-index="${index}">
            <img src="${photo.url}" alt="${photo.caption || 'Photo'}" class="gallery-thumbnail">
            <div class="gallery-item-overlay">
                <p class="gallery-item-caption">${photo.caption || 'Sans légende'}</p>
                <div class="gallery-item-actions">
                    <button class="btn-icon edit-photo-btn" data-index="${index}" title="Modifier">
                        ✏️
                    </button>
                    <button class="btn-icon delete-photo-btn" data-index="${index}" title="Supprimer">
                        🗑️
                    </button>
                </div>
            </div>
        </div>
    `).join('');
}

// ===== RENDER VIDEOS LIST =====
function renderVideosList(videos) {
    if (!Array.isArray(videos)) {
        console.warn('Videos is not an array:', videos);
        return '<div class="empty-state"><p>🎥 Aucune vidéo</p></div>';
    }
    return videos.map((video, index) => {
        const videoId = extractYouTubeId(video.url);
        const thumbnailUrl = videoId ? `https://img.youtube.com/vi/${videoId}/mqdefault.jpg` : '';
        
        return `
            <div class="gallery-item video-item" data-index="${index}">
                ${thumbnailUrl ? `
                    <img src="${thumbnailUrl}" alt="${video.title}" class="gallery-thumbnail">
                ` : `
                    <div class="video-placeholder">🎥</div>
                `}
                <div class="gallery-item-overlay">
                    <p class="gallery-item-caption">${video.title}</p>
                    <div class="gallery-item-actions">
                        <button class="btn-icon edit-video-btn" data-index="${index}" title="Modifier">
                            ✏️
                        </button>
                        <button class="btn-icon delete-video-btn" data-index="${index}" title="Supprimer">
                            🗑️
                        </button>
                    </div>
                </div>
            </div>
        `;
    }).join('');
}

// ===== EXTRACT YOUTUBE ID =====
function extractYouTubeId(url) {
    if (!url) return null;
    const regExp = /^.*(youtu.be\/|v\/|u\/\w\/|embed\/|watch\?v=|&v=)([^#&?]*).*/;
    const match = url.match(regExp);
    return (match && match[2].length === 11) ? match[2] : null;
}

// ===== BIND GALLERY EVENTS =====
function bindGalleryEvents() {
    // Add photo button
    const addPhotoBtn = document.getElementById('add-photo-btn');
    if (addPhotoBtn) {
        addPhotoBtn.addEventListener('click', () => openPhotoModal());
    }
    
    // Add video button
    const addVideoBtn = document.getElementById('add-video-btn');
    if (addVideoBtn) {
        addVideoBtn.addEventListener('click', () => openVideoModal());
    }
    
    // Edit/Delete photo buttons
    document.querySelectorAll('.edit-photo-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            openPhotoModal(index);
        });
    });
    
    document.querySelectorAll('.delete-photo-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            deletePhoto(index);
        });
    });
    
    // Edit/Delete video buttons
    document.querySelectorAll('.edit-video-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            openVideoModal(index);
        });
    });
    
    document.querySelectorAll('.delete-video-btn').forEach(btn => {
        btn.addEventListener('click', (e) => {
            const index = parseInt(e.target.dataset.index);
            deleteVideo(index);
        });
    });
    
    // Photo modal events
    const photoModal = document.getElementById('photo-modal');
    const photoForm = document.getElementById('photo-form');
    const cancelPhotoBtn = document.getElementById('cancel-photo-btn');
    
    if (photoModal) {
        photoModal.querySelector('.modal-close').addEventListener('click', () => {
            photoModal.classList.remove('active');
        });
        
        photoModal.addEventListener('click', (e) => {
            if (e.target === photoModal) {
                photoModal.classList.remove('active');
            }
        });
    }
    
    if (cancelPhotoBtn) {
        cancelPhotoBtn.addEventListener('click', () => {
            photoModal.classList.remove('active');
        });
    }
    
    if (photoForm) {
        photoForm.addEventListener('submit', (e) => {
            e.preventDefault();
            savePhoto();
        });
    }
    
    // Video modal events
    const videoModal = document.getElementById('video-modal');
    const videoForm = document.getElementById('video-form');
    const cancelVideoBtn = document.getElementById('cancel-video-btn');
    
    if (videoModal) {
        videoModal.querySelector('.modal-close').addEventListener('click', () => {
            videoModal.classList.remove('active');
        });
        
        videoModal.addEventListener('click', (e) => {
            if (e.target === videoModal) {
                videoModal.classList.remove('active');
            }
        });
    }
    
    if (cancelVideoBtn) {
        cancelVideoBtn.addEventListener('click', () => {
            videoModal.classList.remove('active');
        });
    }
    
    if (videoForm) {
        videoForm.addEventListener('submit', (e) => {
            e.preventDefault();
            saveVideo();
        });
    }
    
    // Language tabs for both modals
    document.querySelectorAll('.lang-tab').forEach(tab => {
        tab.addEventListener('click', (e) => {
            const lang = e.target.dataset.lang;
            const modal = e.target.closest('.modal');
            
            // Update active tab
            modal.querySelectorAll('.lang-tab').forEach(t => t.classList.remove('active'));
            e.target.classList.add('active');
            
            // Show/hide fields based on modal type
            if (modal.id === 'photo-modal') {
                ['fr', 'en', 'sk', 'ua'].forEach(l => {
                    const label = document.getElementById(`caption-label-${l}`);
                    const input = document.getElementById(`photo-caption-${l}`);
                    if (label && input) {
                        label.style.display = l === lang ? '' : 'none';
                        input.style.display = l === lang ? '' : 'none';
                    }
                });
            } else if (modal.id === 'video-modal') {
                ['fr', 'en', 'sk', 'ua'].forEach(l => {
                    const label = document.getElementById(`video-title-label-${l}`);
                    const input = document.getElementById(`video-title-${l}`);
                    if (label && input) {
                        label.style.display = l === lang ? '' : 'none';
                        input.style.display = l === lang ? '' : 'none';
                    }
                });
            }
        });
    
    });
}

// ===== OPEN PHOTO MODAL =====
function openPhotoModal(index = -1) {
    const modal = document.getElementById('photo-modal');
    const form = document.getElementById('photo-form');
    const t = (key) => typeof adminI18n !== 'undefined' ? adminI18n.t(key) : key;
    
    form.reset();
    document.getElementById('photo-index').value = index;
    
    if (index >= 0) {
        const photo = galleryData.fr.photos[index];
        document.getElementById('photo-modal-title').textContent = t('galleryManager.editPhoto');
        document.getElementById('photo-url').value = photo.url || '';
        
        // Load captions for all languages
        ['fr', 'en', 'sk', 'ua'].forEach(lang => {
            const langPhoto = galleryData[lang].photos[index];
            const input = document.getElementById(`photo-caption-${lang}`);
            if (input && langPhoto) {
                input.value = langPhoto.caption || '';
            }
        });
    } else {
        document.getElementById('photo-modal-title').textContent = t('galleryManager.addPhoto');
    }
    
    modal.classList.add('active');
}

    
    // Setup browse photo button (must be after modal is shown)
    setupBrowsePhotoButton();
