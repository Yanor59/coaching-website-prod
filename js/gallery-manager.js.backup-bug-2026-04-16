// ===== SETUP BROWSE PHOTO BUTTON =====
function setupBrowsePhotoButton() {
    const browsePhotoBtn = document.getElementById('browse-photo-btn');
    const photoFileInput = document.getElementById('photo-file-input');
    
    if (!browsePhotoBtn || !photoFileInput) return;
    
    // Remove existing listeners by cloning
    const newBrowseBtn = browsePhotoBtn.cloneNode(true);
    browsePhotoBtn.parentNode.replaceChild(newBrowseBtn, browsePhotoBtn);
    
    const newFileInput = photoFileInput.cloneNode(true);
    photoFileInput.parentNode.replaceChild(newFileInput, photoFileInput);
    
    // Add click listener
    newBrowseBtn.addEventListener('click', () => {
        newFileInput.click();
    });
    
    // Add change listener
    newFileInput.addEventListener('change', async (e) => {
        const file = e.target.files[0];
        if (!file) return;
        
        // Validate file type
        if (!file.type.startsWith('image/')) {
            alert('❌ Veuillez sélectionner une image (JPG, PNG, WebP)');
            return;
        }
        
        // Validate file size (5MB max)
        if (file.size > 5 * 1024 * 1024) {
            alert('❌ L\'image est trop grande (max 5 MB)');
            return;
        }
        
        // Show loading state
        newBrowseBtn.disabled = true;
        newBrowseBtn.textContent = '⏳ Upload...';
        
        try {
            // Create FormData
            const formData = new FormData();
            formData.append('image', file);
            
            // Upload to server
            const response = await fetch('upload-image.php', {
                method: 'POST',
                body: formData
            });
            
            if (!response.ok) {
                throw new Error('Upload failed');
            }
            
            const result = await response.json();
            
            if (result.success) {
                // Set the uploaded image path in the input
                document.getElementById('photo-url').value = result.path;
                showNotification('✅ Image uploadée avec succès!', 'success');
            } else {
                throw new Error(result.error || 'Upload failed');
            }
        } catch (error) {
            console.error('Upload error:', error);
            showNotification('❌ Erreur lors de l\'upload: ' + error.message, 'error');
        } finally {
            // Reset button state
            newBrowseBtn.disabled = false;
            newBrowseBtn.textContent = '📁 ' + (typeof adminI18n !== 'undefined' ? adminI18n.t('contentEditor.browseImage') : 'Parcourir');
            newFileInput.value = '';
        }
    });
}